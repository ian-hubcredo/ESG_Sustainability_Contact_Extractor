      "id": "f22f7e46-6ea7-4a82-b95c-2a2ea6ae50c6",
      "name": "Apollo People Search",
      "credentials": {
        "httpHeaderAuth": {
          "id": "<REDACTED_CREDENTIAL_ID>", "name": "<REDACTED_CREDENTIAL_NAME>"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// n8n Code node — Build Apollo Mixed People Search POST body (USA + Europe)\n// Target: Sustainability/ESG/Climate/Carbon Leadership\n// Director, Senior Manager, VP, Head, CSO/CXO level\n\n// 1) Inputs\nconst items = $input.all();\n\n// 2) Extract domains from company_website field\nconst allDomains = Array.from(new Set(\n  items\n    .map(it => {\n      const website = String(it.json?.company_website || '').trim();\n      if (!website) return '';\n      \n      // Extract domain from URL\n      try {\n        const url = new URL(website);\n        return url.hostname.replace(/^www\\./, ''); // Remove www. prefix\n      } catch (e) {\n        // If URL parsing fails, try manual extraction\n        return website\n          .replace(/^https?:\\/\\//i, '') // Remove protocol\n          .replace(/^www\\./, '')         // Remove www.\n          .split('/')[0]                 // Get domain only\n          .trim();\n      }\n    })\n    .filter(d => d && d.includes('.'))\n));\n\n// Guard\nif (allDomains.length === 0) {\n  return [{ json: { error: 'No valid domains found' } }];\n}\n\n// 3) Sustainability/ESG/Climate/Carbon Leadership Titles\nconst titles = [\n  // C-Suite / Chief Officers\n  'Chief Sustainability Officer',\n  'CSO',\n  'Chief Environmental Officer',\n  'Chief ESG Officer',\n  'Chief Climate Officer',\n  \n  // VP Level\n  'Vice President of Sustainability',\n  'VP of Sustainability',\n  'VP Sustainability',\n  'Vice President of ESG',\n  'VP of ESG',\n  'VP ESG',\n  'Vice President of Climate',\n  'VP of Climate',\n  'Vice President Environmental',\n  'VP Environmental',\n  \n  // Head Level\n  'Head of Sustainability',\n  'Head of ESG',\n  'Head of Climate',\n  'Head of Environmental',\n  'Head of Carbon',\n  'Sustainability Head',\n  'ESG Head',\n  'Climate Head',\n  \n  // Director Level\n  'Director of Sustainability',\n  'Sustainability Director',\n  'Director of ESG',\n  'ESG Director',\n  'Director of Climate',\n  'Climate Director',\n  'Director of Environmental',\n  'Environmental Director',\n  'Director of Carbon',\n  'Carbon Director',\n  \n  // Senior Manager Level\n  'Senior Manager Sustainability',\n  'Senior Sustainability Manager',\n  'Senior Manager ESG',\n  'Senior ESG Manager',\n  'Senior Manager Climate',\n  'Senior Climate Manager',\n  'Senior Manager Environmental',\n  'Senior Manager Carbon'\n];\n\n// 4) Build POST body for mixed_people/search (USA + Europe filter)\nconst body = {\n  person_titles: titles,\n  person_current_titles: titles,\n  q_organization_domains_list: allDomains,\n  person_locations: ['United States', 'Europe'],  // <-- USA + Europe filter\n  page: 1,\n  per_page: 10\n};\n\n// 5) Output for HTTP Request node\nreturn [{\n  json: {\n    url: 'https://api.apollo.io/api/v1/mixed_people/search',\n    method: 'POST',\n    body,\n    processedDomainCount: allDomains.length,\n    processedDomains: allDomains,\n    targetTitles: titles.length,\n    locationFilter: 'United States, Europe',\n    targetICP: 'Sustainability/ESG/Climate/Carbon Leaders'\n  }\n}];"
      },
